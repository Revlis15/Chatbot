TAVILY_API_KEY=
OPENROUTER_API_KEY=
OPENROUTER_MODEL=nvidia/nemotron-3-super-120b-a12b:free
HF_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
HF_CACHE_FOLDER=/app/cache
HF_TOKEN=
HF_HUB_DISABLE_TELEMETRY=1

# Optional LangSmith tracing (safe to leave unset)
LANGCHAIN_API_KEY=
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=research-assistant-demo

# App -> MCP server base URL (Docker: http://mcp:8000, Local: http://localhost:8000)
MCP_URL=http://mcp:8000